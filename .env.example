# ============================================================
# VirtuAI Environment Variables
#
# Copy to .env and fill in the keys you actually use. Anything
# left blank falls back to mock/dry-run mode where possible
# instead of crashing.
#
#     cp .env.example .env
# ============================================================

# ── KIE.ai unified gateway (REQUIRED for cloud pipeline) ──────────────────────
# Drives Claude Sonnet 4.6 (script writing + viral idea funnel),
# Kling 3.0 multi-shot (reels with native lipsync), Nano Banana 2
# (carousels/portraits), and Suno (instrumental underbeds).
KIE_API_KEY=

# ── Composio (publishing — REQUIRED for live posts) ───────────────────────────
# Without this, Publisher Agent runs in DRY-RUN mode and writes
# would-be requests to virtuai/data/logs/composio_dry_run.jsonl.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# ── Instagram (used by Composio's Instagram actions) ──────────────────────────
IG_USER_ID=
IG_DEMO_IMAGE_URL=

# ── Facebook Page (used by Composio FACEBOOK_CREATE_POST) ─────────────────────
FB_PAGE_ID=
# FB_PAGE_ACCESS_TOKEN=   # OPTIONAL — enables a deeper Facebook health probe;
#                          # without it the health-check simply marks FB "skipped".

# ── YouTube (direct OAuth — bypasses Composio's broken YT wrapper) ────────────
# Composio's YOUTUBE_UPLOAD_VIDEO drops the COPPA flag and YouTube
# rejects every upload. We use the direct API instead.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# X / Twitter was dropped on 2026-05-21 and replaced with Facebook as the
# 4th active platform. See virtuai/config/platforms/facebook.yaml. The
# Composio Facebook connection (under entity COMPOSIO_USER_ID above) is
# what makes FB publishing work — no extra env vars needed beyond FB_PAGE_ID.

# ── Instagram direct Graph API (OPTIONAL — for true 5-slide swipe carousels) ─
# Without this, a 5-slide carousel falls back to publishing slide 1 as a
# single image. Get a long-lived token from Composio dashboard → Connected
# Accounts → Instagram, OR from Meta for Developers → Graph API Explorer
# with scopes: instagram_basic, instagram_content_publish, pages_show_list.
# IG_ACCESS_TOKEN=

# ── Opt-in safety flags ──────────────────────────────────────────────────────
# Both default to false. Enable only when needed.
#
# VIRTUAI_TRUST_KIE_CDN — temporary workaround for KIE's tempfile CDN cert
# chain. When true AND the URL host is in the allowlist
# (tempfile.aiquickdraw.com), SSL verification is disabled for THAT one
# request. Never relaxes verification for api.kie.ai or any other host.
# VIRTUAI_TRUST_KIE_CDN=false
#
# VIRTUAI_VALIDATE_AGENT_OUTPUTS — run Pydantic validation on every agent's
# JSON output. Failures land in virtuai/data/logs/agent_validation_errors.jsonl
# but never crash the pipeline.
# VIRTUAI_VALIDATE_AGENT_OUTPUTS=false

# ── Local backend override (rarely needed) ────────────────────────────────────
# Override the default Phase-1 backend URL (default: http://localhost:8765)
# VIRTUAI_BACKEND_URL=http://localhost:8765
