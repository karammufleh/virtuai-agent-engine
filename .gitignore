# ============================================================
# VirtuAI — .gitignore
# Goal: commit the clean cloud/Claude system only.
# Never commit secrets, virtualenvs, or multi-GB model weights/media.
# ============================================================

# ── Secrets (NEVER commit) ───────────────────────────────────
.env
.env.local
*.env
!.env.example
virtuai/persona/secrets/
virtuai/persona/composio_cache.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.pytest_cache/

# ── IDE / OS ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Large model weights & ML binaries (regenerated, not source) ─
*.safetensors
*.pth
*.pth.tar
*.ckpt
*.pkl
*.pk1
*.dat
*.onnx
*.bin
*.pt

# ── Phase-1 local model stacks (multi-GB; archived locally) ──
virtuai/models/finetune/fused_model/
virtuai/persona/sadtalker/
virtuai/persona/wav2lip/
virtuai/persona/liveportrait/
virtuai/persona/video_retalking/
virtuai/persona/talking_head/
virtuai/persona/voice_clone/
virtuai/persona/training_runs/
virtuai/persona/training_logs/
virtuai/persona/face_dataset/
virtuai/persona/demo/
training_runs_20260426_080218/

# ── Generated media (regenerated by the pipeline) ────────────
virtuai/data/generated_videos/
virtuai/data/generated_images/
virtuai/data/content_packages/*.json
virtuai/data/logs/*.log
virtuai/data/logs/*.jsonl

# ── Phase-1 showcase website (archived locally) ──────────────
virtuai/website/

# ── Local archive folder (relocation target, local only) ─────
archive/
