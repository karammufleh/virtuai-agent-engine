        "specifyBody": "json",
        "jsonBody": "={\n  \"input\": {\n    \"prompt\": \"Decide content_type (data-driven from analyzer best_content_types + verdict) and platform routing per the fixed rule (reel -> instagram+youtube_shorts; portrait/carousel -> instagram only). Do NOT decide a posting time.\",\n    \"context\": {\n      \"analyzer_output\": {{ JSON.stringify($('📊 Analyzer').item.json.output) }},\n      \"research_output\": {{ JSON.stringify($json.output) }}\n    }\n  }\n}",
        "options": {
          "timeout": 1800000
