        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"input\": {\n    \"prompt\": \"Read the most recently published post's metrics. Output a JSON verdict: verdict (positive|negative|neutral), next_direction (do_similar|do_different|continue), recommendation.\"\n  }\n}",
        "options": {
          "timeout": 1800000
        }
      },
