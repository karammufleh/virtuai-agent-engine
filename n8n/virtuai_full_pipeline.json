        "jsonBody": "={\n  \"input\": {\n    \"prompt\": \"TEXT QUALITY CHECK ONLY — NO VIDEO YET. Check the Creator's written content against PROJECT_STANDARDS: hook strength, concrete anchors, banned phrases, sentiment match. Verdict PASS or REVISE. If REVISE, send_agent_message to creator with specific issues.\",\n    \"context\": { \"creator_output\": {{ JSON.stringify($json.output) }}, \"phase\": \"pre-render\" }\n  }\n}",
        "options": {
          "timeout": 1800000
        }
      },
