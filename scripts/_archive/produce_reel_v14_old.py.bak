#!/usr/bin/env python3
"""
produce_reel_v14.py — andyhan.ai-style: Veo 3.1 single-pass reels.

Architecture:
  1. DeepSeek (niche-locked: AI/automation business) writes 3-scene script
  2. Veo 3.1 generates 3 cinematic 8-second clips in PARALLEL:
       - Each clip uses canonical_daniel.png as REFERENCE_2_VIDEO
       - Dialogue embedded in prompt ('says: "..."') → native lipsync
       - Selfie-stick / handheld POV → live background motion
       - 9:16 vertical, 1080p
  3. Concat into ~22-24s reel (native voice throughout)
  4. Suno music underneath at -22 dB
  5. NO captions, NO Avatar Pro, NO compositing

Veo's joint video+audio generation gives:
  - Perfect lipsync (generated together, not retimed)
  - Live backgrounds (people walking, traffic, leaves moving)
  - Real cinematic motion (selfie-stick handheld feel)
"""
from __future__ import annotations

import concurrent.futures as cf
import json
import logging
import os
import subprocess
import sys
import time
from pathlib import Path

import httpx
from dotenv import load_dotenv

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))
load_dotenv(ROOT / ".env")

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(name)s: %(message)s",
)
log = logging.getLogger("produce_reel_v14")

OUTPUT_DIR = ROOT / "virtuai" / "data" / "generated_videos"
SCRIPT_DIR = ROOT / "virtuai" / "data" / "scripts"
SCRIPT_DIR.mkdir(parents=True, exist_ok=True)

KIE_API_KEY = os.environ.get("KIE_API_KEY", "").strip()
KIE_VEO_BASE = "https://api.kie.ai/api/v1/veo"
KIE_API_BASE = "https://api.kie.ai/api/v1"
FFMPEG = "/opt/homebrew/opt/ffmpeg@7/bin/ffmpeg"
FFPROBE = "/opt/homebrew/opt/ffmpeg@7/bin/ffprobe"

CANONICAL_FACE = ROOT / "virtuai" / "persona" / "canonical_daniel.png"
N_SCENES = 3  # 3 × 8s = ~24s reel

POLL_INTERVAL = 10
POLL_TIMEOUT = 1500  # Veo can take 5-10 min per clip


def _headers():
    return {"Authorization": f"Bearer {KIE_API_KEY}", "Content-Type": "application/json"}


def upload_to_tmpfiles(filepath):
    with open(filepath, "rb") as f:
        r = httpx.post("https://tmpfiles.org/api/v1/upload",
                       files={"file": (filepath.name, f)}, timeout=180)
    r.raise_for_status()
    return r.json()["data"]["url"].replace("tmpfiles.org/", "tmpfiles.org/dl/", 1)


def video_dur(p):
    r = subprocess.run([FFPROBE, "-v", "quiet", "-print_format", "json",
                       "-show_format", str(p)], capture_output=True, text=True)
    return float(json.loads(r.stdout)["format"]["duration"])


# ── Veo 3.1 API ─────────────────────────────────────────────────────────────

def submit_veo(prompt: str, image_urls: list[str], scene_name: str) -> str:
    body = {
        "model": "veo3_fast",
        "generationType": "REFERENCE_2_VIDEO",
        "prompt": prompt,
        "imageUrls": image_urls[:3],
        "aspect_ratio": "9:16",
        "resolution": "1080p",
        "enableTranslation": False,
        "callBackUrl": "https://example.com/veo-cb",
    }
    r = httpx.post(f"{KIE_VEO_BASE}/generate", headers=_headers(),
                   json=body, timeout=30)
    r.raise_for_status()
    data = r.json().get("data") or {}
    tid = data.get("taskId")
    if not tid:
        raise RuntimeError(f"Veo submit failed for {scene_name}: {r.text[:400]}")
    log.info(f"  Veo task {scene_name}: {tid[:10]}")
    return tid


def poll_veo(task_id: str, label: str) -> dict:
    deadline = time.time() + POLL_TIMEOUT
    last = ""
    while time.time() < deadline:
        r = httpx.get(f"{KIE_VEO_BASE}/record-info",
                      params={"taskId": task_id}, headers=_headers(), timeout=30)
        r.raise_for_status()
        d = r.json().get("data", {})
        state = d.get("state") or d.get("status") or ""
        success_flag = d.get("successFlag")
        marker = f"state={state!r} flag={success_flag!r}"
        if marker != last:
            log.info(f"  {label}: {marker}")
            last = marker
        if success_flag == 1 or state in ("success", "completed", "succeed", "SUCCESS"):
            return d
        if (isinstance(success_flag, int) and success_flag in (2, 3)) \
                or state in ("failed", "error", "fail", "FAILED"):
            raise RuntimeError(f"{label} failed: {d.get('errorMessage') or d}")
        time.sleep(POLL_INTERVAL)
    raise TimeoutError(label)


def fetch_veo_video(task_id: str, name: str) -> Path:
    data = poll_veo(task_id, name)
    urls = []
    resp_inner = data.get("response") or {}
    if isinstance(resp_inner, dict):
        urls = resp_inner.get("resultUrls") or []
    if not urls:
        urls = data.get("resultUrls") or []
    if not urls and data.get("resultJson"):
        try:
            urls = json.loads(data["resultJson"]).get("resultUrls", [])
        except Exception:
            pass
    if not urls:
        raise RuntimeError(f"No video URL in Veo response: {data}")

    out = OUTPUT_DIR / f"v14_{name}_{int(time.time())}.mp4"
    with httpx.Client(timeout=600, follow_redirects=True) as c:
        dl = c.get(urls[0])
        dl.raise_for_status()
        out.write_bytes(dl.content)
    log.info(f"  ↓ {out.name} ({out.stat().st_size/1024/1024:.1f}MB)")
    return out


# ── Suno ────────────────────────────────────────────────────────────────────

def submit_suno() -> str | None:
    body = {
        "prompt": ("Subtle confident underscore for a business AI vlog. Soft "
                   "synth pad with warm low-end, ambient and contemplative, "
                   "no percussion. Instrumental."),
        "customMode": False, "instrumental": True, "model": "V3_5",
        "callBackUrl": "https://example.com/suno-cb",
    }
    r = httpx.post(f"{KIE_API_BASE}/generate", headers=_headers(),
                   json=body, timeout=30)
    if r.status_code != 200:
        log.warning(f"Suno submit: {r.text[:200]}")
        return None
    return (r.json().get("data") or {}).get("taskId")


def fetch_suno(task_id: str) -> Path | None:
    if not task_id:
        return None
    deadline = time.time() + POLL_TIMEOUT
    last = ""
    final_d = None
    while time.time() < deadline:
        r = httpx.get(f"{KIE_API_BASE}/generate/record-info",
                      params={"taskId": task_id}, headers=_headers(), timeout=30)
        r.raise_for_status()
        d = r.json().get("data", {})
        status = d.get("status", "")
        if status != last:
            log.info(f"  Suno: {status}")
            last = status
        if status == "SUCCESS":
            final_d = d
            break
        if status in ("FAILED", "ERROR", "CALLBACK_EXCEPTION"):
            log.warning(f"Suno failed")
            return None
        time.sleep(POLL_INTERVAL)
    if not final_d:
        return None

    resp_inner = final_d.get("response") or {}
    sd = resp_inner.get("sunoData", []) if isinstance(resp_inner, dict) else []
    if not sd:
        return None
    audio_url = sd[0].get("audioUrl") or sd[0].get("streamAudioUrl", "")
    if not audio_url:
        return None
    out = OUTPUT_DIR / f"v14_music_{int(time.time())}.mp3"
    with httpx.Client(timeout=300, follow_redirects=True) as c:
        dl = c.get(audio_url)
        dl.raise_for_status()
        out.write_bytes(dl.content)
    log.info(f"  ↓ {out.name}")
    return out


# ── Prompt builder ──────────────────────────────────────────────────────────

def build_veo_prompt(scene: dict, scene_idx: int) -> str:
    """
    Veo 3.1 prompt with:
      - selfie-stick / handheld POV (Daniel walks while talking)
      - dialogue embedded as `says: "..."` for native lipsync
      - environmental motion baked in
      - voice direction
    """
    audio_text = scene["audio_text"].strip().replace('"', '\\"')
    visual = scene["visual_prompt"]

    return (
        f"Daniel (a 28-year-old man with short dark wavy hair, light stubble, "
        f"wearing a dark polo shirt) holds a selfie stick (that's where the "
        f"camera is). {visual} He looks directly at the camera and says: "
        f'"{audio_text}" '
        f"Handheld POV vlog framing, natural daylight, ambient environmental "
        f"sound, real-life motion in background (people walking, leaves "
        f"moving, traffic). Confident slightly raspy young male voice with "
        f"calm authority. Documentary realism, NOT cinematic-fantasy. "
        f"No text overlays, no captions in the image."
    )


# ── Stitching + post ────────────────────────────────────────────────────────

def concat_clips(clips: list[Path]) -> Path:
    log.info(f"Concat {len(clips)} Veo clips...")
    work = OUTPUT_DIR / f"_v14_work_{int(time.time())}"
    work.mkdir(exist_ok=True)

    normed = []
    for i, c in enumerate(clips):
        out = work / f"clip_{i:02d}.mp4"
        subprocess.run([
            FFMPEG, "-y", "-i", str(c),
            "-vf", "scale=720:1280:force_original_aspect_ratio=increase,crop=720:1280,setsar=1",
            "-r", "30",
            "-c:v", "libx264", "-preset", "fast", "-crf", "18",
            "-c:a", "aac", "-b:a", "192k",
            str(out),
        ], check=True, capture_output=True)
        normed.append(out)

    list_file = work / "concat.txt"
    list_file.write_text("\n".join(f"file '{p.resolve()}'" for p in normed))
    out = work / "combined.mp4"
    subprocess.run([
        FFMPEG, "-y", "-f", "concat", "-safe", "0", "-i", str(list_file),
        "-c", "copy", str(out),
    ], check=True, capture_output=True)
    log.info(f"  Combined: {video_dur(out):.1f}s")
    return out


def post_produce(video: Path, music: Path | None) -> Path:
    log.info("Post: natural look + music mix + handle (no captions)...")
    work = video.parent

    natural = work / "natural.mp4"
    vf = (
        "scale=720:1280:force_original_aspect_ratio=increase,crop=720:1280,setsar=1,"
        "eq=contrast=1.02:saturation=1.00:gamma=1.0,"
        "noise=alls=6:allf=t+u"
    )
    subprocess.run([
        FFMPEG, "-y", "-i", str(video),
        "-vf", vf,
        "-r", "30",
        "-c:v", "libx264", "-preset", "medium", "-crf", "18",
        "-c:a", "copy",
        str(natural),
    ], check=True, capture_output=True)

    dur = video_dur(natural)
    if music and music.exists():
        mixed = work / "mixed.mp4"
        subprocess.run([
            FFMPEG, "-y", "-i", str(natural), "-i", str(music),
            "-filter_complex",
            f"[0:a]loudnorm=I=-14:LRA=11:tp=-1[dlg];"
            f"[1:a]volume=0.06,afade=t=in:st=0:d=1.5,afade=t=out:st={dur-1.5}:d=1.5[bg];"
            f"[dlg][bg]amix=inputs=2:duration=first:dropout_transition=0[a]",
            "-map", "0:v", "-map", "[a]",
            "-c:v", "copy", "-c:a", "aac", "-b:a", "192k",
            str(mixed),
        ], check=True, capture_output=True)
        source = mixed
    else:
        normed = work / "normed.mp4"
        subprocess.run([
            FFMPEG, "-y", "-i", str(natural),
            "-af", "loudnorm=I=-14:LRA=11:tp=-1",
            "-c:v", "copy", "-c:a", "aac", "-b:a", "192k",
            str(normed),
        ], check=True, capture_output=True)
        source = normed

    burn = (
        "drawtext=text='@daniel.calder'"
        ":font='Inter':fontsize=20:fontcolor=white@0.55"
        ":borderw=1:bordercolor=black@0.5"
        ":x=20:y=h-40"
    )
    ts = int(time.time())
    final = OUTPUT_DIR / f"daniel_reel_v14_{ts}.mp4"
    subprocess.run([
        FFMPEG, "-y", "-i", str(source),
        "-vf", burn,
        "-c:v", "libx264", "-preset", "medium", "-crf", "20",
        "-pix_fmt", "yuv420p",
        "-c:a", "aac", "-b:a", "192k",
        "-movflags", "+faststart",
        "-r", "30",
        str(final),
    ], check=True, capture_output=True)
    return final


# ── main ─────────────────────────────────────────────────────────────────────

def main():
    t0 = time.time()
    log.info("=" * 60)
    log.info("VirtuAI — andyhan-style Reel v14 (Veo 3.1)")
    log.info("=" * 60)

    if not CANONICAL_FACE.exists():
        raise FileNotFoundError(CANONICAL_FACE)

    # Step 1: niche-locked viral script
    log.info("Step 1: DeepSeek script (niche: AI+automation business)...")
    from virtuai.tools.script_writer import write_script
    script = write_script(topic=None, n_scenes=N_SCENES)
    script_path = SCRIPT_DIR / f"v14_{int(time.time())}.json"
    script_path.write_text(json.dumps(script, indent=2))
    log.info(f"  Topic: {script['topic']}")
    log.info(f"  Hook:  {script['hook_summary']}")
    log.info(f"  Scenes: {len(script['scenes'])}")

    scenes = script["scenes"][:N_SCENES]

    log.info("Step 2: Upload canonical Daniel...")
    canonical_url = upload_to_tmpfiles(CANONICAL_FACE)
    ref_urls = [canonical_url]

    log.info(f"Step 3: Submit {len(scenes)} Veo clips + Suno in parallel...")
    with cf.ThreadPoolExecutor(max_workers=5) as ex:
        clip_futs = []
        for i, scene in enumerate(scenes):
            prompt = build_veo_prompt(scene, i)
            log.info(f"  Clip {i+1} prompt ({len(prompt)} chars)")
            log.info(f"    Says: \"{scene['audio_text'][:80]}...\"")
            clip_futs.append((scene.get("id", i + 1),
                              ex.submit(submit_veo, prompt, ref_urls, f"clip{i+1}")))
        suno_fut = ex.submit(submit_suno)

        clip_tasks = [(sid, f.result()) for sid, f in clip_futs]
        suno_task = suno_fut.result()

    log.info("Step 4: Fetching Veo clips + Suno music in parallel...")
    with cf.ThreadPoolExecutor(max_workers=5) as ex:
        clip_fetch_futs = [(sid, ex.submit(fetch_veo_video, tid, f"clip{sid}"))
                           for sid, tid in clip_tasks]
        suno_fetch_fut = ex.submit(fetch_suno, suno_task) if suno_task else None

        clips = [f.result() for _, f in clip_fetch_futs]
        music = suno_fetch_fut.result() if suno_fetch_fut else None

    log.info("Step 5: Concat clips...")
    combined = concat_clips(clips)

    log.info("Step 6: Post production...")
    final = post_produce(combined, music)

    elapsed = time.time() - t0
    log.info("=" * 60)
    log.info(f"DONE in {elapsed:.0f}s ({elapsed/60:.1f} min)")
    log.info(f"Final: {final}")
    log.info(f"Duration: {video_dur(final):.1f}s")
    log.info(f"Size: {final.stat().st_size/1024/1024:.1f} MB")
    log.info("=" * 60)


if __name__ == "__main__":
    main()
